{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://weather-detective/case.schema.json",
  "title": "WeatherDetectiveCase",
  "description": "기상 미스터리 탐정 - 단일 사건(케이스)의 데이터 계약. 프론트 엔진/데이터 파이프라인/AI 프롬프트 세 갈래가 공유한다.",
  "type": "object",
  "required": ["id", "version", "meta", "investigation", "hypotheses", "solution", "learning", "dataSources"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "케이스 고유 id (예: case-01-late-spring-snow)",
      "pattern": "^case-[0-9]{2}-[a-z0-9-]+$"
    },
    "version": { "type": "string", "description": "케이스 데이터 버전" },
    "dataStatus": {
      "type": "string",
      "enum": ["placeholder", "verified"],
      "description": "placeholder = 구조만 채운 예시값. verified = 1단계에서 실제 KMA 데이터로 교체 완료. 부정행위 공개검증 대비용."
    },
    "meta": {
      "type": "object",
      "required": ["title", "difficulty", "targetAudience", "briefing", "event"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string", "description": "사건 제목 (브리핑 헤드라인)" },
        "subtitle": { "type": "string" },
        "difficulty": { "type": "integer", "minimum": 1, "maximum": 3, "description": "1=쉬움 ~ 3=어려움. 사건 순서/난이도 곡선용" },
        "targetAudience": { "type": "string", "description": "예: 중학생" },
        "estimatedMinutes": { "type": "integer", "minimum": 1 },
        "event": {
          "type": "object",
          "required": ["date", "region", "phenomenon"],
          "additionalProperties": false,
          "description": "실제 과거 사례의 시점·지역·현상",
          "properties": {
            "date": { "type": "string", "description": "사례 발생일 (예: 2023-04-25). placeholder 단계에선 비워둘 수 있음" },
            "region": { "type": "string" },
            "phenomenon": { "type": "string" }
          }
        },
        "briefing": { "type": "string", "description": "사용자에게 보여줄 사건 브리핑 본문" }
      }
    },
    "investigation": {
      "type": "object",
      "required": ["clues"],
      "additionalProperties": false,
      "properties": {
        "maxInvestigations": {
          "type": "integer",
          "minimum": 0,
          "description": "조사 가능 횟수 제약(추리 긴장감). 0이면 제약 없음"
        },
        "clues": {
          "type": "array",
          "minItems": 3,
          "description": "단서 레이어. 사용자가 하나씩 열어 관측값을 확인한다. 최소 3개(평가표 '단서 3개 이상' 기준).",
          "items": { "$ref": "#/definitions/clue" }
        }
      }
    },
    "hypotheses": {
      "type": "object",
      "required": ["prompt", "options"],
      "additionalProperties": false,
      "properties": {
        "prompt": { "type": "string", "description": "가설 제출 질문 (예: 이 현상의 원인은?)" },
        "options": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/definitions/hypothesis" }
        }
      }
    },
    "solution": {
      "type": "object",
      "required": ["mechanism", "causalChain", "keyFactors"],
      "additionalProperties": false,
      "properties": {
        "mechanism": { "type": "string", "description": "정답 메커니즘 서술" },
        "causalChain": {
          "type": "array",
          "items": { "type": "string" },
          "description": "인과 체인. 해설 화면에서 단계별로 시각화"
        },
        "keyFactors": {
          "type": "array",
          "items": { "type": "string" },
          "description": "정답 판단의 핵심 요인 (가설 채점 기준과 연결)"
        }
      }
    },
    "misconceptions": {
      "type": "array",
      "description": "흔한 오개념과 교정 메시지. AI 튜터가 교정에 활용",
      "items": {
        "type": "object",
        "required": ["id", "trigger", "correction"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "trigger": { "type": "string", "description": "오개념 진술 (예: 온난화인데 폭설? 온난화는 거짓)" },
          "correction": { "type": "string" }
        }
      }
    },
    "aiTutor": {
      "type": "object",
      "description": "3단계 AI 연동에서 LLM에 주입할 컨텍스트. 0단계에선 정의만, 호출은 안 함.",
      "additionalProperties": false,
      "properties": {
        "systemContext": { "type": "string", "description": "정답·단서·오개념 요약. LLM 시스템 프롬프트 주입용" },
        "rules": {
          "type": "array",
          "items": { "type": "string" },
          "description": "예: 정답 누설 금지 / 놓친 단서를 질문으로 유도 / 출력은 JSON"
        },
        "hintLadder": {
          "type": "array",
          "items": { "type": "string" },
          "description": "점진적 유도 힌트 (AI 폴백 시 정적 힌트로도 사용)"
        }
      }
    },
    "learning": {
      "type": "object",
      "required": ["concepts", "summary"],
      "additionalProperties": false,
      "properties": {
        "concepts": { "type": "array", "items": { "type": "string" }, "description": "교과 개념 (예: 기단, 대기 안정도)" },
        "summary": { "type": "string", "description": "사건 해결 후 학습 정리 텍스트" },
        "curriculumLink": { "type": "string", "description": "교육과정 연계 (예: 중학교 과학 - 기권과 날씨)" }
      }
    },
    "dataSources": {
      "type": "array",
      "minItems": 1,
      "description": "데이터 출처. 공고의 부정행위 공개검증(코드/데이터 표절 검증) 대비. 데이터 1종 이상 명시는 평가표 '실현 가능성' 요건.",
      "items": {
        "type": "object",
        "required": ["name", "portal"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "description": "예: 종관기상관측(ASOS)" },
          "portal": { "type": "string", "description": "예: data.kma.go.kr" },
          "retrieved": { "type": "string", "description": "수집 일자" },
          "note": { "type": "string" }
        }
      }
    }
  },
  "definitions": {
    "clue": {
      "type": "object",
      "required": ["id", "title", "type", "summary"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string", "description": "단서 카드 제목 (예: 지상 기압배치)" },
        "type": {
          "type": "string",
          "enum": ["pressure-map", "temp-comparison", "upper-air", "timeseries", "wind", "sst", "text"],
          "description": "시각화 컴포넌트 종류. 2단계에서 type별 렌더러를 붙인다. 0단계에선 카드 메타만 사용."
        },
        "locked": { "type": "boolean", "default": true, "description": "초기 잠금 상태. true면 사용자가 열어야 보임" },
        "cost": { "type": "integer", "minimum": 0, "default": 1, "description": "이 단서를 여는 데 드는 조사 횟수" },
        "summary": { "type": "string", "description": "단서를 열었을 때 보이는 한 줄 요약(헤드라인)" },
        "data": { "type": "object", "description": "시각화용 데이터. type별 구조가 다르며 2단계 렌더러가 해석. 0단계에선 통과만." },
        "interpretationHint": { "type": "string", "description": "이 단서가 의미하는 바. 해설 단계에서만 노출" }
      }
    },
    "hypothesis": {
      "type": "object",
      "required": ["id", "text", "verdict"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string", "description": "가설 선택지 문구" },
        "verdict": {
          "type": "string",
          "enum": ["correct", "partial", "misconception"],
          "description": "정답/부분정답/오개념"
        },
        "requiredClues": {
          "type": "array",
          "items": { "type": "string" },
          "description": "이 가설을 제대로 판단하려면 봤어야 하는 단서 id 목록 (AI 피드백/채점에 활용)"
        },
        "feedback": { "type": "string", "description": "해당 가설 선택 시 정적 피드백 (AI 폴백용)" }
      }
    }
  }
}
